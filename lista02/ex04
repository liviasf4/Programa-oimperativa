#include <stdio.h>
#include <math.h>
#include <stdlib.h>
#include <string.h>

int main(){

int q;
int X;
char C;
int linhas = 0;
int primeiro_c = 0;
int esp = 0; //esp do D(o limite do E)
int d_se_foi = 0; //saber se o primeiro d se foi
int j = 0; //pra usar no while do E
int cursor = 0;
int flag_foi_b = 'A';

int c = 0;

scanf("%d", &q);

while (linhas < q){

    scanf("%d %c", &X, &C);

    if (C == 'E'){
        cursor -= X;
    }

    if ((primeiro_c == 0) && (C == 'E')){

        primeiro_c = 1;
         
        printf("Informacao invalida\n"); //SE A PRIMEIRA ENTRADA FOR E, ? INVALIDA
        linhas = q;

    }else{

        primeiro_c = 1;


        for (int i = 0; i < X; i++){

        if (C == 'D'){ //DIREITA

            if (d_se_foi == 1){

                if (i == 0){

                    while (c < cursor - 1){
                    printf(" ");
                    c += 1;
                }
                c = 0;
                }
            }

            if ((flag_foi_b == 'B') && (i == X - 1)){ //indica que foi b
                printf(".");
            }

            if (i == 0){
                cursor += X;
            }
           
            if ((d_se_foi == 0) && (i == X - 1)){
                d_se_foi = 1;
               
            }
            
            printf(".");

        }else if (C == 'E'){ //ESQUERDA

            if (cursor - 1 < 0){
                printf("Informacao invalida\n");
                i = X;

            }else{

                if (i == 0){

                    while (j < cursor - 1){
                    printf(" ");
                    j += 1;
                }

                j = 0;

                }
                
                printf(".");

                if ((flag_foi_b == 'B') && (i == X - 1)){ //indica que foi b
                    flag_foi_b = 'A';
                    printf(".");
                }
                
            }

        } else if(C == 'B'){ //BAIXO
    
            int b = 0;
            flag_foi_b = 'B';
            if (i == 0){
                printf("\n");
            }
            if (i < X - 1){
                while (b < cursor - 1){
                    printf(" ");
                    b += 1;
                }
                b = 0;
                printf(".\n");
            } else {
                if (linhas == q - 1){
                    while (b < cursor - 1){
                        printf(" ");
                        b += 1;
                    }
                    b = 0;
                    printf(".");
                }
            }
        }

    }

    }

    linhas += 1;
}    

return 0;

}
