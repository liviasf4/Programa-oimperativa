#include <stdio.h>

int main(){

    int i = 0;
    int j = 0;
    int T, N, X;

    scanf("%d", &T);

    while(i < T){

        scanf("%d", &N);
        int seq[N];

        while(j < N){
            scanf("%d", &X);
            seq[j] = X;
            j += 1;
        }
        j = 0;

        //variï¿½veis da sequï¿½ncia atual
        int inicio_atual = 0;
        int tamanho_atual = 1;

        //variï¿½veis da melhor sequï¿½ncia
        int inicio_melhor = 0;
        int tamanho_melhor = 1;

        int k = 1;
        while(k < N){

            if(seq[k] < seq[k-1]){
                // continua decrescendo
                tamanho_atual += 1;

            } else {
                // sequï¿½ncia quebrou ? compara com a melhor
                if(tamanho_atual > tamanho_melhor){
                    tamanho_melhor = tamanho_atual;
                    inicio_melhor = inicio_atual;
                }
                // comeï¿½a nova sequï¿½ncia
                inicio_atual = k;
                tamanho_atual = 1;
            }

            k += 1;
        }

        // verifica a ï¿½ltima sequï¿½ncia
        if(tamanho_atual > tamanho_melhor){
            tamanho_melhor = tamanho_atual;
            inicio_melhor = inicio_atual;
        }

        // saï¿½da
        if(tamanho_melhor == 1){
            printf("0\n");
        } else {
            printf("%d\n", tamanho_melhor);
            int f = 0;
            while(f < tamanho_melhor){
                printf("%d ", seq[inicio_melhor + f]);
                f += 1;
            }
            printf("\n");
        }
        i += 1;
    }

    return 0;
}
