#include <stdio.h>

#define MAX 100

void aplicar_enfeites(char matriz[MAX][MAX], char res[MAX][MAX], int m, int n) {

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {

            if (matriz[i][j] == 'P') {

                // CRUZ (+)
                if (i - 1 >= 0 && matriz[i-1][j] == '-') res[i-1][j] = '+';
                if (i + 1 < m && matriz[i+1][j] == '-') res[i+1][j] = '+';
                if (j - 1 >= 0 && matriz[i][j-1] == '-') res[i][j-1] = '+';
                if (j + 1 < n && matriz[i][j+1] == '-') res[i][j+1] = '+';

                // DIAGONAIS (x)
                if (i - 1 >= 0 && j - 1 >= 0 && matriz[i-1][j-1] == '-' && res[i-1][j-1] != '+') res[i-1][j-1] = 'x';
                if (i - 1 >= 0 && j + 1 < n && matriz[i-1][j+1] == '-' && res[i-1][j+1] != '+') res[i-1][j+1] = 'x';
                if (i + 1 < m && j - 1 >= 0 && matriz[i+1][j-1] == '-' && res[i+1][j-1] != '+') res[i+1][j-1] = 'x';
                if (i + 1 < m && j + 1 < n && matriz[i+1][j+1] == '-' && res[i+1][j+1] != '+') res[i+1][j+1] = 'x';
            }
        }
    }
}

int main() {
    char matriz[MAX][MAX];
    char res[MAX][MAX];
    int m, n;

    scanf("%d %d", &m, &n);

    for (int i = 0; i < m; i++) {
        scanf("%s", matriz[i]);

        // copia inicial
        for (int j = 0; j < n; j++) {
            res[i][j] = matriz[i][j];
        }
    }

    aplicar_enfeites(matriz, res, m, n);

    // imprime resultado
    for (int i = 0; i < m; i++) {
        printf("%s\n", res[i]);
    }

    return 0;
}
