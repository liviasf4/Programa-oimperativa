#include <stdio.h>

int i = 0; // linha (global)
int j = 0; // coluna (global)

// função 
void posicoes(int matriz[4][4], char letra){

    int dentro_do_lim = 0;

    if (letra == 'c'){
        if (i >= 1){
            i -= 1;
            dentro_do_lim = 1;
        }
    } else if (letra == 'b'){
        if (i <= 2){
            i += 1;
            dentro_do_lim = 1;
        }
    } else if (letra == 'e'){
        if (j >= 1){
            j -= 1;
            dentro_do_lim = 1;
        }
    } else if (letra == 'd'){
        if (j <= 2){
            j += 1;
            dentro_do_lim = 1;
        }
    }

    if(dentro_do_lim == 1){
        matriz[i][j] += 1;
    }
}

int main(){

    int matriz[4][4] = {{0}};
    char seq;
    int x = 0;

    int linha_proibida = 0;
    int coluna_proibida = 0;
    int maior = -1;

    while(x < 20){
        if (x != 19){
            scanf("%c ", &seq);
        } else {
            scanf("%c", &seq);
        }

        posicoes(matriz, seq);

        x += 1;
    }

    for (int w = 0; w < 4; w++){
        for (int z = 0; z < 4; z++){
            if(matriz[w][z] > maior){
                maior = matriz[w][z];
                linha_proibida = w;
                coluna_proibida = z;
            }
        }
    }

    printf("Coordenada X:%d, Y:%d\n", coluna_proibida, linha_proibida);
}
